<?php

return [
    'class' => 'yii\db\Connection',
    'dsn' => sprintf(
        'mysql:host=%s;port=%s;dbname=%s',
        getenv('DB_HOST') ?: 'db',
        getenv('DB_PORT') ?: '3306',
        getenv('DB_NAME') ?: 'goal'
    ),
    'username' => getenv('DB_USERNAME') ?: 'goal',
    'password' => getenv('DB_PASSWORD') ?: 'goal',
    'charset' => 'utf8',
];
